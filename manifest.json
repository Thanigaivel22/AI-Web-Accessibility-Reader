{
  "manifest_version": 3,
  "name": "AI Web Accessibility Reader",
  "version": "1.0",
  "description": "Analyzes webpages and reads content aloud intelligently.",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
} 